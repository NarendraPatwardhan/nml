diff --git a/csrc/flash_attn/src/nml_cuda_check.h b/csrc/flash_attn/src/nml_cuda_check.h
new file mode 100644
index 0000000..4e6f1a9
--- /dev/null
+++ b/csrc/flash_attn/src/nml_cuda_check.h
@@ -0,0 +1,29 @@
+#pragma once
+
+#if !defined(__CUDACC_RTC__)
+#include <cuda_runtime.h>
+#endif
+
+#include <stdexcept>
+#include <string>
+
+namespace nml_flash_attention {
+inline void check_cuda(cudaError_t status, const char *expression) {
+    if (status == cudaSuccess) {
+        return;
+    }
+    throw std::runtime_error(
+        std::string(expression) + ": " + cudaGetErrorString(status));
+}
+}  // namespace nml_flash_attention
+
+#define NML_CUDA_CHECK(call)                                                   \
+    do {                                                                       \
+        nml_flash_attention::check_cuda((call), #call);                        \
+    } while (0)
+
+#define NML_CUDA_KERNEL_LAUNCH_CHECK()                                         \
+    do {                                                                       \
+        nml_flash_attention::check_cuda(cudaGetLastError(),                    \
+                                        "CUDA kernel launch");                 \
+    } while (0)
