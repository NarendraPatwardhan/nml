# NML keeps repository-wide Bazel policy deliberately small. Backend-specific
# flags belong beside the backend that consumes them; putting them here would
# make every target depend on implementation details of XLA, PJRT, or CUDA.

# Keep Bazel's mutable server state and action cache outside the source tree at
# the single relative location established in FORK.md. Because this is a
# startup option, it applies equally to local Bazel and BuildBuddy Remote Bazel.
startup --output_user_root=../nml-bazel-cache

# A failed test should explain itself in the terminal while preserving Bazel's
# complete test log as the authoritative artifact.
test --test_output=errors

# XLA/LLVM require C++17. Keeping the language level repository-wide matches
# the ZML graph and prevents build tools from selecting a host compiler default.
common --cxxopt=-std=c++17
common --host_cxxopt=-std=c++17

# Bazel 9 removed the legacy native C++, Python, shell, and Java rules that
# XLA's pinned LLVM BUILD files still spell without explicit loads. Route those
# names through the same external rule sets ZML selects.
common --incompatible_autoload_externally=+@rules_cc,+@rules_python,+@rules_shell,+@rules_java

# The generated upb runtime is linked into shared compiler/runtime boundaries.
common:linux --copt=-fPIC

# Named backend configurations are permanent acceptance entry points. CUDA is
# additive: its configuration retains the CPU correctness/performance backend.
common:cpu --//platforms:cpu=true
common:cpu --//platforms:cuda=false
common:cuda --//platforms:cpu=true
common:cuda --//platforms:cuda=true

# BuildBuddy is opt-in because unauthenticated/offline development remains a
# supported workflow.  The bb CLI supplies the user's credential; no account
# secret belongs in the repository.  Minimal downloads keep LLVM/XLA actions
# remote while still materializing binaries and runfiles needed by local GPU
# contracts.
common:buildbuddy --bes_results_url=https://app.buildbuddy.io/invocation/
common:buildbuddy --bes_backend=grpcs://remote.buildbuddy.io
common:buildbuddy --remote_cache=grpcs://remote.buildbuddy.io
common:buildbuddy --remote_download_minimal
common:buildbuddy --remote_cache_compression

# Performance is a product property, so optimized builds have a stable spelling.
# The default remains Bazel's fast development mode; performance gates must opt
# into this configuration explicitly rather than accidentally benchmarking it.
build:release --compilation_mode=opt
test:release --compilation_mode=opt
