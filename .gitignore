# Bazel creates convenience symlinks in the repository root. Their targets live
# in Bazel's output base and are machine-local, so neither the links nor their
# contents belong in source control.
/bazel-*

# The BuildBuddy CLI materializes remotely built artifacts here when a local
# command consumes them. They are cache products, not repository inputs.
/bb-out/

# Real model repositories are local product inputs. Their upstream revisions
# and hashes belong in the model contract, while multi-gigabyte checkpoint and
# tokenizer artifacts never enter NML's Git history.
/models/

# ZML is a continuously readable reference checkout, not an NML source or build
# dependency. Its exact revision is recorded in FORK.md instead of vendoring its
# Git history into NML.
/references/

# NML is Bazel-owned. These directories are ignored defensively so an ad-hoc
# Cargo invocation cannot introduce a second build-output tree into commits.
/target/
**/target/

# Host filesystem and editor recovery files carry no product state.
.DS_Store
**/.DS_Store
*.swp
*.swo
*~
